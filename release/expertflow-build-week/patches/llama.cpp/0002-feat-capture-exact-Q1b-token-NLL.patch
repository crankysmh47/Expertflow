@@ -469,6 +473,21 @@ static results_perplexity perplexity(llama_context * ctx, const common_params &
         logits_stream.write(reinterpret_cast<const char *>(&n_ctx), sizeof(n_ctx));
     }
 
+    std::ofstream nll_stream;
+    const char * nll_path = getenv("LLAMA_EXPERTFLOW_NLL_FILE");
+    if (nll_path != nullptr && nll_path[0] != '\0') {
