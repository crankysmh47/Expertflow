+                                   << R"(,"position":)" << first + k + 1
+                                   << R"(,"token_id":)" << tokens_data[k + 1]
+                                   << R"(,"nll":)" << token_nll_history[k] << "}\n";
+                    }
+                }
             }
             count += n_ctx - first - 1;
 
