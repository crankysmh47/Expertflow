+        nll_stream.open(nll_path, std::ios::out | std::ios::trunc);
+        if (!nll_stream.is_open()) {
+            LOG_ERR("%s: failed to open %s for writing\n", __func__, nll_path);
+            return {};
+        }
+        nll_stream << std::setprecision(17);
