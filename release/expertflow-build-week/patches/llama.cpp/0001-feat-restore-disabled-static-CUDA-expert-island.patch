 #define tensor_id_copy(id, backend_id, copy_id) sched->hv_tensor_copies[(id) * sched->n_backends * sched->n_copies + (backend_id) * sched->n_copies + (copy_id)]
 #define tensor_copy(tensor, backend_id, copy_id) tensor_id_copy(hash_id(tensor), backend_id, copy_id)
 
+static bool expertflow_static_island_input(const ggml_backend_sched_t sched, const struct ggml_tensor * tensor) {
+    if (sched->expertflow_static_island_layer < 0 || tensor == nullptr) {
+        return false;
+    }
+
+    char prefix[64];
+    snprintf(prefix, sizeof(prefix), "blk.%d.ffn_", sched->expertflow_static_island_layer);
+    const size_t prefix_len = strlen(prefix);
+    return strncmp(tensor->name, prefix, prefix_len) == 0 && strstr(tensor->name + prefix_len, "_exps.") != nullptr;
+}
+
+static struct expertflow_static_island_shadow * expertflow_static_island_find_shadow(
+        ggml_backend_sched_t sched,
+        const struct ggml_tensor * source) {
+    for (int i = 0; i < sched->expertflow_static_island_n_shadows; ++i) {
+        if (sched->expertflow_static_island_shadows[i].source == source) {
+            return &sched->expertflow_static_island_shadows[i];
+        }
+    }
+    return nullptr;
+}
+
+static struct ggml_tensor * expertflow_static_island_get_shadow(
+        ggml_backend_sched_t sched,
+        struct ggml_tensor * source,
+        int backend_id) {
+    struct expertflow_static_island_shadow * existing = expertflow_static_island_find_shadow(sched, source);
+    if (existing != nullptr) {
+        return existing->shadow;
+    }
+
+    if (sched->expertflow_static_island_n_shadows >= EXPERTFLOW_STATIC_ISLAND_MAX_SHADOWS) {
+        GGML_ABORT("ExpertFlow static island exceeded %d shadow tensors\n", EXPERTFLOW_STATIC_ISLAND_MAX_SHADOWS);
+    }
+
+    struct expertflow_static_island_shadow * entry =
+        &sched->expertflow_static_island_shadows[sched->expertflow_static_island_n_shadows++];
+    struct ggml_init_params params = {
+        /* .mem_size   = */ 2 * ggml_tensor_overhead(),
+        /* .mem_buffer = */ nullptr,
+        /* .no_alloc   = */ true,
+    };
+    entry->ctx = ggml_init(params);
+    if (entry->ctx == nullptr) {
+        GGML_ABORT("ExpertFlow static island failed to allocate shadow metadata\n");
+    }
+    entry->source = source;
+    entry->shadow = ggml_dup_tensor_layout(entry->ctx, source);
+    ggml_format_name(entry->shadow, "EXPERTFLOW_STATIC#%s", source->name);
+    entry->buffer = ggml_backend_alloc_ctx_tensors_from_buft(entry->ctx, sched->bufts[backend_id]);
+    if (entry->buffer == nullptr) {
+        GGML_ABORT("ExpertFlow static island failed to allocate CUDA shadow for %s\n", source->name);
+    }
+    ggml_backend_buffer_set_usage(entry->buffer, GGML_BACKEND_BUFFER_USAGE_WEIGHTS);
+    entry->loaded = false;
+    return entry->shadow;
+}
+
+static bool expertflow_static_island_preload(
+        ggml_backend_sched_t sched,
+        ggml_backend_t backend,
+        struct ggml_tensor * source,
+        struct ggml_tensor * shadow) {
+    struct expertflow_static_island_shadow * entry = expertflow_static_island_find_shadow(sched, source);
+    if (entry == nullptr || entry->shadow != shadow) {
+        GGML_ABORT("ExpertFlow static island shadow mapping is stale for %s\n", source->name);
+    }
+    if (entry->loaded) {
+        return true;
+    }
+    if (source->data == nullptr || ggml_nbytes(source) != ggml_nbytes(shadow)) {
+        GGML_ABORT("ExpertFlow static island source contract failed for %s\n", source->name);
+    }
+
+    ggml_backend_tensor_set_async(backend, shadow, source->data, 0, ggml_nbytes(source));
+    entry->loaded = true;
+    GGML_LOG_INFO("ExpertFlow static island preloaded %s: %zu bytes\n", source->name, ggml_nbytes(source));
+    return true;
+}
