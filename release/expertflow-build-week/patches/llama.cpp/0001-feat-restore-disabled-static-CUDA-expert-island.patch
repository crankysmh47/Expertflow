+++ b/src/llama-context.cpp
@@ -23,6 +23,85 @@
 // llama_context
 //
 
+static int expertflow_static_island_layer() {
+    const char * value = getenv("LLAMA_EXPERTFLOW_STATIC_ISLAND_LAYER");
+    if (value == nullptr || value[0] == '\0') {
+        return -1;
+    }
+
+    char * end = nullptr;
+    const long layer = strtol(value, &end, 10);
+    if (end == value || *end != '\0' || layer < 0 || layer > INT32_MAX) {
+        LLAMA_LOG_ERROR("invalid LLAMA_EXPERTFLOW_STATIC_ISLAND_LAYER: %s\n", value);
+        return -1;
+    }
+    return (int) layer;
+}
+
+static void expertflow_static_island_assign_chain(
+        ggml_backend_sched_t sched,
+        ggml_backend_t       backend,
+        ggml_tensor *        tensor,
+        int                  depth) {
+    if (tensor == nullptr || depth > 8) {
+        return;
+    }
+
+    switch (tensor->op) {
+        case GGML_OP_MUL_MAT_ID:
+            ggml_backend_sched_set_tensor_backend(sched, tensor, backend);
+            return;
+        case GGML_OP_MUL:
+            ggml_backend_sched_set_tensor_backend(sched, tensor, backend);
+            expertflow_static_island_assign_chain(sched, backend, tensor->src[0], depth + 1);
+            return;
+        case GGML_OP_GLU:
+            ggml_backend_sched_set_tensor_backend(sched, tensor, backend);
+            expertflow_static_island_assign_chain(sched, backend, tensor->src[0], depth + 1);
+            expertflow_static_island_assign_chain(sched, backend, tensor->src[1], depth + 1);
+            return;
+        case GGML_OP_GET_ROWS:
+        case GGML_OP_REPEAT:
+        case GGML_OP_RESHAPE:
+        case GGML_OP_VIEW:
+            ggml_backend_sched_set_tensor_backend(sched, tensor, backend);
+            expertflow_static_island_assign_chain(sched, backend, tensor->src[0], depth + 1);
+            return;
+        default:
+            return;
+    }
+}
+
+static void expertflow_static_island_assign(
+        ggml_backend_sched_t sched,
+        ggml_backend_t       backend,
+        ggml_backend_t       original_backend,
+        ggml_tensor *        tensor,
+        const char *         name,
+        int                  layer,
+        int                  target_layer) {
+    if (target_layer < 0 || layer != target_layer || backend == nullptr) {
+        return;
+    }
+
+    if (strcmp(name, "ffn_moe_weighted") == 0 || strcmp(name, "ffn_moe_out") == 0) {
+        ggml_backend_sched_set_tensor_backend(sched, tensor, original_backend);
+        return;
+    }
+
+    const bool is_expert_node =
+        strcmp(name, "ffn_moe_gate_up") == 0 ||
+        strcmp(name, "ffn_moe_up")      == 0 ||
+        strcmp(name, "ffn_moe_gate")    == 0 ||
+        strcmp(name, "ffn_moe_geglu")   == 0 ||
+        strcmp(name, "ffn_moe_swiglu")  == 0 ||
+        strcmp(name, "ffn_moe_reglu")   == 0 ||
+        strcmp(name, "ffn_moe_down")    == 0;
+    if (is_expert_node) {
+        expertflow_static_island_assign_chain(sched, backend, tensor, 0);
+    }
+}
